{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Web 3 Browser",
  "version": "0.3.4",
  "identifier": "com.rohithchelli.web3browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Web 3 Browser",
        "width": 1200,
        "height": 800,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
